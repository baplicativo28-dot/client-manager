rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica se o usuário autenticado não está bloqueado.
    // Usa != true para lidar com campo ausente (null != true → true).
    function isNotBlocked() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.blocked != true;
    }

    // Verifica se o usuário autenticado é admin
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.role == 'admin';
    }

    // Perfis de usuário
    match /users/{uid} {
      // Usuário lê o próprio perfil
      allow read: if request.auth != null && request.auth.uid == uid;

      // Usuário cria o próprio perfil (primeiro login → role: admin)
      allow create: if request.auth != null && request.auth.uid == uid;

      // Usuário atualiza o próprio perfil
      allow update: if request.auth != null && request.auth.uid == uid;

      // Admin lê perfis dos seus revendedores
      allow read: if request.auth != null
                   && isAdmin()
                   && resource.data.createdBy == request.auth.uid;

      // Admin cria doc de revendedor (com createdBy apontando para si)
      allow create: if request.auth != null
                     && isAdmin()
                     && request.resource.data.createdBy == request.auth.uid
                     && request.resource.data.role == 'reseller'
                     && isNotBlocked();

      // Admin atualiza revendedores seus (blocked, etc.)
      allow update: if request.auth != null
                     && isAdmin()
                     && resource.data.createdBy == request.auth.uid
                     && isNotBlocked();

      // Admin deleta perfil de revendedor que criou
      allow delete: if request.auth != null
                     && isAdmin()
                     && resource.data.createdBy == request.auth.uid
                     && isNotBlocked();
    }

    // Clientes: acesso somente ao próprio usuário, somente se não bloqueado
    match /users/{uid}/clients/{clientId} {
      allow read, write: if request.auth != null
                          && isNotBlocked()
                          && (request.auth.uid == uid
                              || (isAdmin() && get(/databases/$(database)/documents/users/$(uid)).data.createdBy == request.auth.uid));
    }

    // Configurações: acesso somente ao próprio usuário, somente se não bloqueado
    match /users/{uid}/settings/{settingsDoc} {
      allow read, write: if request.auth != null
                          && isNotBlocked()
                          && (request.auth.uid == uid
                              || (isAdmin() && get(/databases/$(database)/documents/users/$(uid)).data.createdBy == request.auth.uid));
    }

    // Financeiro: produtos e lançamentos do próprio usuário, somente se não bloqueado
    match /users/{uid}/financeProducts/{docId} {
      allow read, write: if request.auth != null
                          && isNotBlocked()
                          && (request.auth.uid == uid
                              || (isAdmin() && get(/databases/$(database)/documents/users/$(uid)).data.createdBy == request.auth.uid));
    }

    match /users/{uid}/financeEntries/{docId} {
      allow read, write: if request.auth != null
                          && isNotBlocked()
                          && (request.auth.uid == uid
                              || (isAdmin() && get(/databases/$(database)/documents/users/$(uid)).data.createdBy == request.auth.uid));
    }
  }
}
